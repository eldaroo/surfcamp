# LobbyPMS API Configuration
LOBBYPMS_API_URL=https://api.lobbypms.com/api/v1
LOBBYPMS_API_KEY=your_lobbypms_api_key_here

# Stripe Configuration (if needed)
STRIPE_SECRET_KEY=sk_test_or_live_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_or_live_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DATABASE_URL=postgresql://user:password@host:5432/postgres
DATABASE_URL_DIRECT=postgresql://user:password@host:5432/postgres

# WeTravel Configuration
WETRAVEL_API_KEY=your_wetravel_api_key_here
WETRAVEL_AUTH_URL=https://api.wetravel.com/v2/auth/tokens/access
WETRAVEL_API_URL=https://api.wetravel.com/v2/payment_links
WETRAVEL_WEBHOOK_SECRET=your_wetravel_webhook_secret_here

# Brevo Email
BREVO_API_KEY=your_brevo_api_key_here
BREVO_TEMPLATE_EN=0
BREVO_TEMPLATE_ES=0

# WhatsApp / Green API
GREEN_API_URL=https://api.green-api.com
GREEN_API_INSTANCE=your_green_api_instance_here
GREEN_API_TOKEN=your_green_api_token_here

# Frontend / Runtime
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_LINK_GENERATOR_URL=http://localhost:3010
PORT=3000
NODE_ENV=production
